# Dockerfile.backup — Agent de sauvegarde Restic
FROM alpine:3.19

# Installation de Restic et des clients de bases de données
RUN apk add --no-cache \
    restic \
    mariadb-client \
    postgresql16-client \
    bash \
    curl \
    tzdata

# Répertoires de travail
RUN mkdir -p /data/bookstack /data/db_data /data/postgres_data /backup_repo /scripts /tmp/dumps

WORKDIR /scripts

# Copie du script de sauvegarde
COPY scripts/backup_script.sh .
RUN chmod +x backup_script.sh

ENTRYPOINT ["/bin/bash", "./backup_script.sh"]
